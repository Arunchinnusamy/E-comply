# E-Comply Backend - Environment Configuration Template
# Copy this file to .env and fill in your values

# Flask Configuration
DEBUG=True
HOST=0.0.0.0
PORT=5000

# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# OCR Configuration
# Path to tesseract executable (leave as 'tesseract' if in PATH)
TESSERACT_CMD=tesseract

# Use EasyOCR as fallback (requires GPU for best performance)
USE_EASYOCR=True

# Server Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:5000

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60

# Cache Configuration (optional)
CACHE_ENABLED=False
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# External APIs (if needed)
# AMAZON_API_KEY=your_key_here
# FLIPKART_API_KEY=your_key_here

# Security
SECRET_KEY=change_this_to_random_secret_key_in_production
